GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1

# ========================================
# MODEL CONFIGURATION
# ========================================

# Gemini model to use (default: gemini-2.0-flash)
MODEL_NAME=gemini-2.0-flash

# ========================================
# RESEARCH SETTINGS
# ========================================

# Maximum iterations for research refinement loop (Lesson 4 - LoopAgent)
MAX_ITERATIONS=3

# Quality threshold for accepting research answers (0.0-1.0)
QUALITY_THRESHOLD=0.8

# ========================================
# CUSTOM RESEARCH QUERY (Optional)
# ========================================

# Set a custom research query (overrides default queries in main.py)
# RESEARCH_QUERY=What are the latest advances in quantum computing?

# ========================================
# SETUP INSTRUCTIONS
# ========================================
#
# Copy this file to .env:
#    cp .env.example .env
#
